# PPI Wallet — Consumer App (paytm-wallet-app)
# Copy this file to `.env` and fill in your own values.
# NEVER commit `.env`.

# Backend API URL (optional — defaults to '' which triggers mock mode)
# Production: https://ppi-wallet-api.onrender.com
# Local dev:  http://localhost:3001
VITE_API_URL=

# Demo mode flag — informational only, not wired yet.
# When production auth lands, setting this to 'false' will disable
# the localStorage fallback and demo PIN (1234).
VITE_DEMO_MODE=true
